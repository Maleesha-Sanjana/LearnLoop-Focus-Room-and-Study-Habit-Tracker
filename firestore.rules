rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId);

      match /profileData/{docId} {
        allow read: if isSignedIn();
        allow write: if isOwner(userId);
      }

      match /goals/{goalId} {
        allow read, write: if isOwner(userId);
      }

      match /activities/{activityId} {
        allow read, write: if isOwner(userId);
      }

      match /resources/{resourceId} {
        allow read, write: if isOwner(userId);
      }

      match /achievements/{achievementId} {
        allow read, write: if isOwner(userId);
      }

      match /notifications/{notificationId} {
        allow read, write: if isOwner(userId);
      }
    }

    match /chats/{chatId} {
      allow read, write: if isSignedIn();

      match /messages/{messageId} {
        allow read, write: if isSignedIn();
      }
    }

    match /quizResults/{resultId} {
      allow read: if true;
      allow create: if isSignedIn()
        && (request.resource.data.uid == request.auth.uid || request.resource.data.demo == true);
      allow update, delete: if isSignedIn()
        && (resource.data.uid == request.auth.uid || resource.data.demo == true);
    }

    match /sessions/{sessionId} {
      allow read, write: if isSignedIn();
    }

    match /quizSets/{setId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /platformStats/{docId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /testimonials/{docId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn();
    }

    match /config/{docId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /teamInvites/{inviteId} {
      allow read, create, update: if isSignedIn();
    }

    match /mail/{mailId} {
      allow create: if isSignedIn();
      allow read, update, delete: if false;
    }
  }
}
